{
  "name": "lxnotes-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test:unit": "turbo run test:unit",
    "test:e2e": "turbo run test:e2e",
    "audit:security": "npm audit --omit=dev --audit-level=high"
  },
  "devDependencies": {
    "supabase": "^2.84.5",
    "turbo": "^2.8.12"
  },
  "dependencies": {
    "tailwindcss": "^4.1.18"
  },
  "overrides": {
    "jspdf": {
      "dompurify": "^3.4.0"
    }
  }
}
