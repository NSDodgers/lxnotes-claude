{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/cleanup-productions",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/cleanup-snapshots",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/auto-snapshot",
      "schedule": "0 */6 * * *"
    }
  ]
}
